    <string name="pdf_guide_general_scale_title">Общая шкала 0–10</string>
    <string name="pdf_guide_scale_0">0 — нет симптома</string>
    <string name="pdf_guide_scale_1_2">1–2 — слабо, почти не мешает</string>
    <string name="pdf_guide_scale_3_4">3–4 — заметно, но контролируемо</string>
    <string name="pdf_guide_scale_5_6">5–6 — мешает, требует усилий</string>
    <string name="pdf_guide_scale_7_8">7–8 — сильно мешает, влияет на дела/сон/общение</string>
    <string name="pdf_guide_scale_9_10">9–10 — почти неуправляемо или опасно</string>

    <string name="pdf_guide_mood_title">Настроение</string>
    <string name="pdf_guide_mood_0_2">0–2 — очень плохо</string>
    <string name="pdf_guide_mood_3_4">3–4 — снижено</string>
    <string name="pdf_guide_mood_5">5 — нейтрально</string>
    <string name="pdf_guide_mood_6_7">6–7 — хорошее, но контролируемое</string>
    <string name="pdf_guide_mood_8">8 — подозрительно приподнято, много идей</string>
    <string name="pdf_guide_mood_9_10">9–10 — разгон/эйфория, трудно остановиться</string>

    <string name="pdf_guide_sleep_title">Сон</string>
    <string name="pdf_guide_sleep_8_10">8–10 ч — нормально/много</string>
    <string name="pdf_guide_sleep_7_8">7–8 ч — хорошо</string>
    <string name="pdf_guide_sleep_6_7">6–7 ч — терпимо</string>
    <string name="pdf_guide_sleep_5_6">5–6 ч — риск</string>
    <string name="pdf_guide_sleep_lt5">&lt;5 ч — красный флаг</string>
    <string name="pdf_guide_sleep_lt4_no_fatigue">&lt;4 ч без усталости — возможный маркер разгона</string>

    <string name="pdf_guide_sleep_ease_title">Засыпание</string>
    <string name="pdf_guide_sleep_ease_0">0 — уснул легко</string>
    <string name="pdf_guide_sleep_ease_1_2">1–2 — немного дольше обычного</string>
    <string name="pdf_guide_sleep_ease_3_4">3–4 — ворочался, но уснул</string>
    <string name="pdf_guide_sleep_ease_5_6">5–6 — долго не мог уснуть</string>
    <string name="pdf_guide_sleep_ease_7_8">7–8 — очень тяжело заснуть</string>
    <string name="pdf_guide_sleep_ease_9_10">9–10 — почти не спал/не мог уснуть</string>

    <string name="pdf_guide_anxiety_title">Тревога</string>
    <string name="pdf_guide_anxiety_0">0 — спокойно</string>
    <string name="pdf_guide_anxiety_1_2">1–2 — лёгкое напряжение</string>
    <string name="pdf_guide_anxiety_3_4">3–4 — заметная тревога, но терпимо</string>
    <string name="pdf_guide_anxiety_5_6">5–6 — мешает фокусироваться</string>
    <string name="pdf_guide_anxiety_7_8">7–8 — почти постоянно крутит</string>
    <string name="pdf_guide_anxiety_9_10">9–10 — невыносимо, почти паника</string>

    <string name="pdf_guide_irritability_title">Раздражительность</string>
    <string name="pdf_guide_irritability_0">0 — спокойно</string>
    <string name="pdf_guide_irritability_1_2">1–2 — чуть раздражительнее</string>
    <string name="pdf_guide_irritability_3_4">3–4 — легко бесился, но держался</string>
    <string name="pdf_guide_irritability_5_6">5–6 — резкость/срывы</string>
    <string name="pdf_guide_irritability_7_8">7–8 — конфликты, сильная злость</string>
    <string name="pdf_guide_irritability_9_10">9–10 — почти не контролирую реакции</string>

    <string name="pdf_guide_impulsivity_title">Импульсивность</string>
    <string name="pdf_guide_impulsivity_0">0 — решения спокойные</string>
    <string name="pdf_guide_impulsivity_1_2">1–2 — чуть больше спонтанности</string>
    <string name="pdf_guide_impulsivity_3_4">3–4 — хочется резко что-то сделать, но контролирую</string>
    <string name="pdf_guide_impulsivity_5_6">5–6 — импульсивные действия/планы/траты/конфликты</string>
    <string name="pdf_guide_impulsivity_7_8">7–8 — трудно остановиться, рискованные действия</string>
    <string name="pdf_guide_impulsivity_9_10">9–10 — опасные действия, потеря контроля</string>

    <string name="pdf_guide_racing_title">Разгон мыслей</string>
    <string name="pdf_guide_racing_0">0 — мысли спокойные</string>
    <string name="pdf_guide_racing_1_2">1–2 — чуть быстрее обычного</string>
    <string name="pdf_guide_racing_3_4">3–4 — много мыслей, но фокус есть</string>
    <string name="pdf_guide_racing_5_6">5–6 — мысли скачут, сложно удерживать линию</string>
    <string name="pdf_guide_racing_7_8">7–8 — поток идей, мешает делам/сну</string>
    <string name="pdf_guide_racing_9_10">9–10 — почти невозможно остановить</string>

    <string name="pdf_guide_apathy_title">Апатия</string>
    <string name="pdf_guide_apathy_0">0 — нормально начинаю дела</string>
    <string name="pdf_guide_apathy_1_2">1–2 — чуть сложнее стартовать</string>
    <string name="pdf_guide_apathy_3_4">3–4 — прокрастинация, но могу включиться</string>
    <string name="pdf_guide_apathy_5_6">5–6 — трудно начать без давления</string>
    <string name="pdf_guide_apathy_7_8">7–8 — почти ничего не начинаю</string>
    <string name="pdf_guide_apathy_9_10">9–10 — полная остановка активности</string>

    <string name="pdf_guide_fatigue_title">Усталость</string>
    <string name="pdf_guide_fatigue_0">0 — бодро</string>
    <string name="pdf_guide_fatigue_1_2">1–2 — лёгкая усталость</string>
    <string name="pdf_guide_fatigue_3_4">3–4 — устал, но дела возможны</string>
    <string name="pdf_guide_fatigue_5_6">5–6 — приходится себя тащить</string>
    <string name="pdf_guide_fatigue_7_8">7–8 — дела сильно страдают</string>
    <string name="pdf_guide_fatigue_9_10">9–10 — почти не функционирую</string>

    <string name="pdf_guide_interest_title">Потеря интереса</string>
    <string name="pdf_guide_interest_0">0 — интересы живые</string>
    <string name="pdf_guide_interest_1_2">1–2 — интерес чуть слабее</string>
    <string name="pdf_guide_interest_3_4">3–4 — меньше удовольствия, но вовлекаюсь</string>
    <string name="pdf_guide_interest_5_6">5–6 — почти ничего не цепляет</string>
    <string name="pdf_guide_interest_7_8">7–8 — даже любимое пустое</string>
    <string name="pdf_guide_interest_9_10">9–10 — всё безразлично</string>

    <string name="pdf_guide_hopelessness_title">Безнадежность</string>
    <string name="pdf_guide_hopelessness_0">0 — будущее нормальное</string>
    <string name="pdf_guide_hopelessness_1_2">1–2 — тревожные сомнения</string>
    <string name="pdf_guide_hopelessness_3_4">3–4 — сложно, но варианты вижу</string>
    <string name="pdf_guide_hopelessness_5_6">5–6 — кажется, что выхода мало</string>
    <string name="pdf_guide_hopelessness_7_8">7–8 — ощущение тупика</string>
    <string name="pdf_guide_hopelessness_9_10">9–10 — опасный уровень, нужна помощь</string>

    <string name="pdf_guide_suicidal_title">Суицидальные мысли</string>
    <string name="pdf_guide_suicidal_intro">Используй текущую шкалу приложения. Если текущая шкала 0–3:</string>
    <string name="pdf_guide_suicidal_0">0 — нет</string>
    <string name="pdf_guide_suicidal_1">1 — пассивные мысли</string>
    <string name="pdf_guide_suicidal_2">2 — частые/навязчивые мысли</string>
    <string name="pdf_guide_suicidal_3">3 — риск или намерение</string>

    <string name="pdf_guide_self_harm_title">Самоповреждение</string>
    <string name="pdf_guide_self_harm_desc">“Да” означает, что в этот день было самоповреждение или действие с намерением причинить себе вред.</string>

