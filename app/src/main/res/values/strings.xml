    <string name="pdf_rating_guide_title">MoodTrack Rating Guide</string>
    <string name="pdf_rating_guide_how_to_read_title">How to read scales</string>
    <string name="pdf_rating_guide_intro">All ratings are subjective self-ratings by the user for the day.</string>
    <string name="pdf_rating_guide_disclaimer_title">Disclaimer</string>
    <string name="pdf_rating_guide_disclaimer">This guide is not a clinical scale. It is intended for consistent diary keeping and discussing changes in condition with a specialist.</string>

    <string name="pdf_guide_general_scale_title">General scale 0–10</string>
    <string name="pdf_guide_scale_0">0 — no symptom</string>
    <string name="pdf_guide_scale_1_2">1–2 — weak, barely interferes</string>
    <string name="pdf_guide_scale_3_4">3–4 — noticeable, but controlled</string>
    <string name="pdf_guide_scale_5_6">5–6 — interferes, requires effort</string>
    <string name="pdf_guide_scale_7_8">7–8 — strongly interferes, affects tasks/sleep/social interaction</string>
    <string name="pdf_guide_scale_9_10">9–10 — almost uncontrollable or dangerous</string>

    <string name="pdf_guide_mood_title">Mood</string>
    <string name="pdf_guide_mood_0_2">0–2 — very bad</string>
    <string name="pdf_guide_mood_3_4">3–4 — low</string>
    <string name="pdf_guide_mood_5">5 — neutral</string>
    <string name="pdf_guide_mood_6_7">6–7 — good, but controlled</string>
    <string name="pdf_guide_mood_8">8 — suspiciously elevated, many ideas</string>
    <string name="pdf_guide_mood_9_10">9–10 — racing/euphoria, hard to stop</string>

    <string name="pdf_guide_sleep_title">Sleep</string>
    <string name="pdf_guide_sleep_8_10">8–10 h — normal/long</string>
    <string name="pdf_guide_sleep_7_8">7–8 h — good</string>
    <string name="pdf_guide_sleep_6_7">6–7 h — tolerable</string>
    <string name="pdf_guide_sleep_5_6">5–6 h — risk</string>
    <string name="pdf_guide_sleep_lt5">&lt;5 h — red flag</string>
    <string name="pdf_guide_sleep_lt4_no_fatigue">&lt;4 h without fatigue — possible marker of racing</string>

    <string name="pdf_guide_sleep_ease_title">Falling asleep</string>
    <string name="pdf_guide_sleep_ease_0">0 — fell asleep easily</string>
    <string name="pdf_guide_sleep_ease_1_2">1–2 — slightly longer than usual</string>
    <string name="pdf_guide_sleep_ease_3_4">3–4 — tossed and turned, but fell asleep</string>
    <string name="pdf_guide_sleep_ease_5_6">5–6 — could not fall asleep for a long time</string>
    <string name="pdf_guide_sleep_ease_7_8">7–8 — very hard to fall asleep</string>
    <string name="pdf_guide_sleep_ease_9_10">9–10 — almost no sleep/could not fall asleep</string>

    <string name="pdf_guide_anxiety_title">Anxiety</string>
    <string name="pdf_guide_anxiety_0">0 — calm</string>
    <string name="pdf_guide_anxiety_1_2">1–2 — light tension</string>
    <string name="pdf_guide_anxiety_3_4">3–4 — noticeable anxiety, but tolerable</string>
    <string name="pdf_guide_anxiety_5_6">5–6 — interferes with focus</string>
    <string name="pdf_guide_anxiety_7_8">7–8 — almost constantly churning</string>
    <string name="pdf_guide_anxiety_9_10">9–10 — unbearable, almost panic</string>

    <string name="pdf_guide_irritability_title">Irritability</string>
    <string name="pdf_guide_irritability_0">0 — calm</string>
    <string name="pdf_guide_irritability_1_2">1–2 — slightly more irritable</string>
    <string name="pdf_guide_irritability_3_4">3–4 — easily annoyed, but held back</string>
    <string name="pdf_guide_irritability_5_6">5–6 — sharpness/outbursts</string>
    <string name="pdf_guide_irritability_7_8">7–8 — conflicts, strong anger</string>
    <string name="pdf_guide_irritability_9_10">9–10 — almost no control over reactions</string>

    <string name="pdf_guide_impulsivity_title">Impulsivity</string>
    <string name="pdf_guide_impulsivity_0">0 — decisions are calm</string>
    <string name="pdf_guide_impulsivity_1_2">1–2 — slightly more spontaneity</string>
    <string name="pdf_guide_impulsivity_3_4">3–4 — want to do something suddenly, but control it</string>
    <string name="pdf_guide_impulsivity_5_6">5–6 — impulsive actions/plans/spending/conflicts</string>
    <string name="pdf_guide_impulsivity_7_8">7–8 — hard to stop, risky actions</string>
    <string name="pdf_guide_impulsivity_9_10">9–10 — dangerous actions, loss of control</string>

    <string name="pdf_guide_racing_title">Racing thoughts</string>
    <string name="pdf_guide_racing_0">0 — thoughts are calm</string>
    <string name="pdf_guide_racing_1_2">1–2 — slightly faster than usual</string>
    <string name="pdf_guide_racing_3_4">3–4 — many thoughts, but focus exists</string>
    <string name="pdf_guide_racing_5_6">5–6 — thoughts jump, hard to keep a line</string>
    <string name="pdf_guide_racing_7_8">7–8 — flow of ideas, interferes with tasks/sleep</string>
    <string name="pdf_guide_racing_9_10">9–10 — almost impossible to stop</string>

    <string name="pdf_guide_apathy_title">Apathy</string>
    <string name="pdf_guide_apathy_0">0 — normal start of activities</string>
    <string name="pdf_guide_apathy_1_2">1–2 — slightly harder to start</string>
    <string name="pdf_guide_apathy_3_4">3–4 — procrastination, but can engage</string>
    <string name="pdf_guide_apathy_5_6">5–6 — hard to start without pressure</string>
    <string name="pdf_guide_apathy_7_8">7–8 — almost nothing started</string>
    <string name="pdf_guide_apathy_9_10">9–10 — complete stop of activity</string>

    <string name="pdf_guide_fatigue_title">Fatigue</string>
    <string name="pdf_guide_fatigue_0">0 — energetic</string>
    <string name="pdf_guide_fatigue_1_2">1–2 — light fatigue</string>
    <string name="pdf_guide_fatigue_3_4">3–4 — tired, but activities are possible</string>
    <string name="pdf_guide_fatigue_5_6">5–6 — have to drag yourself</string>
    <string name="pdf_guide_fatigue_7_8">7–8 — activities strongly suffer</string>
    <string name="pdf_guide_fatigue_9_10">9–10 — almost non-functioning</string>

    <string name="pdf_guide_interest_title">Loss of interest</string>
    <string name="pdf_guide_interest_0">0 — interests are alive</string>
    <string name="pdf_guide_interest_1_2">1–2 — interest slightly weaker</string>
    <string name="pdf_guide_interest_3_4">3–4 — less pleasure, but involved</string>
    <string name="pdf_guide_interest_5_6">5–6 — almost nothing catches</string>
    <string name="pdf_guide_interest_7_8">7–8 — even favorite things feel empty</string>
    <string name="pdf_guide_interest_9_10">9–10 — everything is indifferent</string>

    <string name="pdf_guide_hopelessness_title">Hopelessness</string>
    <string name="pdf_guide_hopelessness_0">0 — future is normal</string>
    <string name="pdf_guide_hopelessness_1_2">1–2 — anxious doubts</string>
    <string name="pdf_guide_hopelessness_3_4">3–4 — difficult, but I see options</string>
    <string name="pdf_guide_hopelessness_5_6">5–6 — it seems there is little way out</string>
    <string name="pdf_guide_hopelessness_7_8">7–8 — feeling of a dead end</string>
    <string name="pdf_guide_hopelessness_9_10">9–10 — dangerous level, help needed</string>

    <string name="pdf_guide_suicidal_title">Suicidal thoughts</string>
    <string name="pdf_guide_suicidal_intro">Uses the current app scale. If the current scale is 0–3:</string>
    <string name="pdf_guide_suicidal_0">0 — no</string>
    <string name="pdf_guide_suicidal_1">1 — passive thoughts</string>
    <string name="pdf_guide_suicidal_2">2 — frequent/intrusive thoughts</string>
    <string name="pdf_guide_suicidal_3">3 — risk or intent</string>

